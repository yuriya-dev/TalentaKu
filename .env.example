# =========================================================================
# TalentaKu Configuration Template
# =========================================================================

# --- Backend Configuration ---
# DATABASE_URL: Path to the SQLite database file or PostgreSQL (Supabase) connection string
# Examples:
# - SQLite: DATABASE_URL=talentaku.db
# - PostgreSQL/Supabase: DATABASE_URL="postgres://postgres:<password>@db.<ref>.supabase.co:5432/postgres?sslmode=require"
DATABASE_URL=talentaku.db

# PORT: Port on which the Fiber backend server runs
PORT=8080

# --- Frontend Configuration ---
# VITE_GOOGLE_CLIENT_ID: Your Google Client ID from Google API Console
# For Google Sign-in to work, this client ID must be configured for the frontend origin.
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
